<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="001-initial-schema" author="ognjen">
        <sqlFile
                path="db/changelog/001-initial-schema.sql"
                splitStatements="false"/>
    </changeSet>

    <changeSet id="002-seed-data" author="ognjen">
        <sqlFile
                path="db/changelog/002-seed-data.sql"
                splitStatements="true"/>
    </changeSet>

    <changeSet id="003-seed-client-accounts" author="account-service">
        <sqlFile
                path="db/changelog/003-seed-client-accounts.sql"
                splitStatements="true"/>
    </changeSet>

    <changeSet id="004-fix-bank-account-concrete" author="account-service">
        <sqlFile
                path="db/changelog/004-fix-bank-account-concrete.sql"
                splitStatements="true"/>
    </changeSet>

    <changeSet id="005-seed-state-company-and-account" author="account-service">
        <sqlFile
                path="db/changelog/005-seed-state-company-and-account.sql"
                splitStatements="true"/>
    </changeSet>

</databaseChangeLog>