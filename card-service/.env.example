# Server
CARD_SERVER_PORT=8087

# JWT (mora biti isti secret kao i u ostalim servisima)
JWT_SECRET=your_jwt_secret_here

# Database
CARD_DB_HOST=localhost
CARD_DB_PORT=5439
CARD_DB_EX_PORT=5439
CARD_DB_INT_PORT=5432
CARD_DB_NAME=card_db
CARD_DB_USER=postgres
CARD_DB_PASSWORD=postgres

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=rabbit
RABBITMQ_PASSWORD=rabbit
NOTIFICATION_EXCHANGE=employee.events
CARD_AUTO_EXCHANGE=employee.events
CARD_AUTO_QUEUE=card-service-auto-card-queue
CARD_AUTO_ROUTING_KEY=card.create

# Service URLs
SERVICES_CLIENT_URL=http://localhost:8083
SERVICES_ACCOUNT_URL=http://localhost:8084
SERVICES_VERIFICATION_URL=http://localhost:8086
SERVICE_VERIFICATION_PORT=8086
