<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Shared Checkstyle configuration for Java/Gradle services in the monorepo.

  Purpose:
  - provide lightweight code style validation
  - keep rules simple and not overly strict
  - run automatically in pre-push hooks and GitHub Actions CI

  Notes:
  - severity is set to warning
  - this config is referenced from each Java service build.gradle
-->

<module name="Checker">
    <property name="severity" value="warning"/>

    <module name="FileTabCharacter"/>
    <!-- Enforce maximum line length, but ignore package/import lines and URLs -->
    <module name="LineLength">
        <property name="max" value="140"/>
        <property name="ignorePattern" value="^package .*|^import .*|https?://.*"/>
    </module>

    <module name="TreeWalker">
        <!-- Avoid wildcard imports such as import java.util.* -->
        <module name="AvoidStarImport"/>
        <!-- Require braces for control structures like if/else/for/while -->
        <module name="NeedBraces"/>
        <!-- Require braces for control structures like if/else/for/while -->
        <module name="WhitespaceAfter"/>
        <!-- Detect and report unused imports -->
        <module name="UnusedImports"/>
        <!-- Detect and report unused imports -->
        <module name="NoWhitespaceBefore"/>
    </module>
</module>